{
  "name": "zhilinclaw",
  "version": "1.0.0",
  "description": "本地优先的开源 AI助手系统 - Local-First AI Assistant Framework (OpenClaw + IronClaw + Hanwudi)",
  "main": "src/core/index.ets",
  "type": "module",
  "scripts": {
    "build": "hvigorw assembleHap --mode module",
    "test": "hvigorw test",
    "lint": "eslint src/**/*.ets",
    "start": "hvigorw run",
    "demo:main": "hvigorw run --entry examples/main.ets",
    "demo:security": "hvigorw run --entry examples/SecurityDemo.ets",
    "demo:hanwudi": "hvigorw run --entry examples/HanwudiDemo.ets",
    "demo:all": "npm run demo:main && npm run demo:security && npm run demo:hanwudi",
    "docs:gen": "echo 'Generating documentation...'",
    "clean": "rm -rf build/ dist/ node_modules/"
  },
  "keywords": [
    "arkts",
    "ai-assistant",
    "local-first",
    "plugin-framework",
    "agent-team",
    "hanwudi",
    "openclaw",
    "ironclaw",
    "openharmony",
    "harmonyos"
  ],
  "author": "zhilinclaw team",
  "license": "Apache-2.0",
  "devDependencies": {
    "@ohos/hvigor-ohos-plugin": "^4.0.0",
    "@ohos/hvigor": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zhilinclaw/zhilinclaw.git"
  },
  "bugs": {
    "url": "https://github.com/zhilinclaw/zhilinclaw/issues"
  },
  "homepage": "https://github.com/zhilinclaw/zhilinclaw#readme"
}
